# AgriVision AI — Backend Environment Variables
# Copy to .env and fill in your values

# ─── Database ──────────────────────────────
DATABASE_URL=postgresql+asyncpg://agrivision:agrivision_pass@db:5432/agrivision_db

# ─── Redis ─────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Security ──────────────────────────────
SECRET_KEY=CHANGE_ME_use_a_256bit_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── External APIs ─────────────────────────
OPENWEATHER_API_KEY=demo_key

# ─── Storage ───────────────────────────────
UPLOAD_DIR=/app/uploads
ML_MODELS_DIR=/app/ml/weights

# ─── App ───────────────────────────────────
ENVIRONMENT=production
PROJECT_NAME=AgriVision AI
VERSION=1.0.0
